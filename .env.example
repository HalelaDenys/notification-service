# middleware
APP_CONFIG__MIDD__CORS_ALLOWED_ORIGINS='["http://localhost", "http://localhost:5173"]'

# Redis
APP_CONFIG__REDIS__HOST=redis
APP_CONFIG__REDIS__PORT=6379
APP_CONFIG__REDIS__DB=0

# Logging
#APP_CONFIG__LOG_CONSOLE_LEVEL=10
#APP_CONFIG__MODE=TEST

# SMTP (Please enter your details)
APP_CONFIG__SMTP__HOST="stmp.gmail.com"
APP_CONFIG__SMTP__PORT="465"
APP_CONFIG__SMTP__USERNAME="test"
APP_CONFIG__SMTP__PASSWORD="test"
APP_CONFIG__SMTP__USE_TLS=TRUE
APP_CONFIG__SMTP__START_TLS=False
APP_CONFIG__SMTP__SENDER="admin@example.com"
APP_CONFIG__SMTP__TIMEOUT=10.0
